# ============================================================
# APEX AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (Required for auth + database) ──────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Map Providers (Optional — OSM is always the fallback) ────
VITE_GRAPHHOPPER_API_KEY=     # Primary routing
VITE_GOOGLE_MAPS_API_KEY=     # Secondary routing + places
VITE_MAPBOX_TOKEN=            # Dark tile layer + routing

# ── AI Providers (Optional — configure in Settings > AI) ─────
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_GROQ_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_MISTRAL_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=

# NOTE: Without Supabase keys, the app loads in demo/preview
# mode — you'll see the login screen but auth won't work.
